PORT=8080
MONGODB_URI=your_mongodb_atlas_uri
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
AWS_REGION=
S3_BUCKET=
S3_PUBLIC_READ=true
# Required for local/dev S3 uploads (on EC2, use an IAM role instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional temporary credentials
# AWS_SESSION_TOKEN=
# Optional override for public URL base (CloudFront/custom domain)
# S3_PUBLIC_BASE_URL=https://cdn.example.com
